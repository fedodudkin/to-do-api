# Конфигурация БД (относительно корня проекта)
DATABASE_PATH=database/app.sqlite

# Конфигурация логов 
LOG_PATH=logs/app.log
LOG_LEVEL=info

# Rate Limiting (по умолчанию: 100 запросов в 60 секунд)
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_SECONDS=60

# Конфигурация приложения
APP_ENV=local
APP_DEBUG=true